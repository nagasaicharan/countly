var fs = require('fs');

describe('Outputing logs', function(){
	describe('userovo-dashboard.log', function(){
		it('should output', function(done){
			fs.readFile('log/userovo-dashboard.log', 'utf8', function (err,data) {
				if (err) {
					console.log(err);
				}
				console.log(data);
				done();
			});
		});
	});
	describe('userovo-api.log', function(){
		it('should output', function(done){
			fs.readFile('log/userovo-api.log', 'utf8', function (err,data) {
				if (err) {
					console.log(err);
				}
				console.log(data);
				done();
			});
		});
	});
});